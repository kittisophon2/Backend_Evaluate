// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String      @unique
  passwordHash String
  role         Role
  departmentId String?     @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())

  // เพิ่ม Relation ฝั่งตรงข้ามที่อ้างอิงมาจาก Assignment
  evaluatorAssignments Assignment[] @relation("Evaluator")
  evaluateeAssignments Assignment[] @relation("Evaluatee")
}

model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  // เพิ่ม Relation ฝั่งตรงข้ามที่อ้างอิงมาจาก User
  users User[]
}

model Evaluation {
  id      String           @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  startAt DateTime
  endAt   DateTime
  status  EvaluationStatus
  topics  Topic[]

  // เพิ่ม Relation ฝั่งตรงข้ามที่อ้างอิงมาจาก Assignment
  assignments Assignment[]
}

model Topic {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  evaluationId String      @db.ObjectId
  name         String
  evaluation   Evaluation  @relation(fields: [evaluationId], references: [id])
  indicators   Indicator[]
}

model Indicator {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  topicId         String        @db.ObjectId
  name            String
  type            IndicatorType
  weight          Float
  requireEvidence Boolean
  topic           Topic         @relation(fields: [topicId], references: [id])
}

model Assignment {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  evaluationId String @db.ObjectId
  evaluatorId  String @db.ObjectId
  evaluateeId  String @db.ObjectId

  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
  evaluator  User       @relation("Evaluator", fields: [evaluatorId], references: [id])
  evaluatee  User       @relation("Evaluatee", fields: [evaluateeId], references: [id])

  @@unique([evaluationId, evaluatorId, evaluateeId])
}

model Evidence {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  indicatorId String   @db.ObjectId
  evaluateeId String   @db.ObjectId
  filePath    String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  @@unique([indicatorId, evaluateeId])
}

model EvaluationResult {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String   @db.ObjectId
  indicatorId  String   @db.ObjectId
  score        Int? // 1–4 or 0/1
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  EVALUATOR
  EVALUATEE
}

enum IndicatorType {
  SCALE_1_4
  YES_NO
}

enum EvaluationStatus {
  DRAFT
  OPEN
  CLOSED
}
