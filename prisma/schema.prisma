generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  users       User[]
  assignments Assignment[] // ✅ เพิ่ม Relation
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  empId        String   @unique
  name         String
  departmentId String   @db.ObjectId
  role         String
  email        String   @unique
  password     String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id])

  createdEvaluations Evaluation[] @relation("EvaluationCreator")
  createdTopics      Topic[]      @relation("TopicCreator")

  evaluatorAssignments Assignment[] @relation("Evaluator")
  evaluateeAssignments Assignment[] @relation("Evaluatee")

  evidences IndicatorEvidence[]
}

// ✅ 1. เพิ่มโมเดล Period (รอบการประเมิน)
model Period {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  startDate DateTime?
  endDate   DateTime?
  status    String   @default("OPEN") 
  createdAt DateTime @default(now())

  assignments Assignment[]
}

model Evaluation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  createdBy String   @db.ObjectId
  createdAt DateTime @default(now())

  creator User @relation("EvaluationCreator", fields: [createdBy], references: [id])

  topics      Topic[]
  assignments Assignment[]
}

model Topic {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  evaluationId String   @db.ObjectId
  name         String
  description  String
  createdBy    String   @db.ObjectId
  createdAt    DateTime @default(now())

  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
  creator    User       @relation("TopicCreator", fields: [createdBy], references: [id])

  indicators Indicator[]
}

model Indicator {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  topicId         String   @db.ObjectId
  name            String
  description     String
  indicatorType   String
  requireEvidence Boolean
  weight          Float
  createdAt       DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id])

  results   IndicatorResult[]
  evidences IndicatorEvidence[]
}

model Assignment {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // ✅ 2. เพิ่มฟิลด์ที่ Controller ต้องการใช้งาน
  periodId     String   @db.ObjectId
  departmentId String   @db.ObjectId
  status       String   @default("DRAFT")

  // ปรับให้ evaluationId เป็น Optional (ใส่ ? ไว้) เพื่อให้สร้างได้แม้ยังไม่ผูกฟอร์ม
  evaluationId String?  @db.ObjectId
  
  evaluatorId  String   @db.ObjectId
  evaluateeId  String   @db.ObjectId
  createdAt    DateTime @default(now())

  // ✅ 3. เชื่อม Relation ให้สมบูรณ์
  period       Period     @relation(fields: [periodId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  evaluation   Evaluation? @relation(fields: [evaluationId], references: [id])

  evaluator User @relation("Evaluator", fields: [evaluatorId], references: [id])
  evaluatee User @relation("Evaluatee", fields: [evaluateeId], references: [id])

  indicatorResults IndicatorResult[]

  // ✅ 4. ป้องกันการจ่ายงานซ้ำ (ผู้ประเมินคนเดิม ประเมินคนถูกประเมินคนเดิม ในรอบเดียวกัน)
  @@unique([periodId, evaluatorId, evaluateeId])
}

model IndicatorResult {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  indicatorId  String   @db.ObjectId
  assignmentId String   @db.ObjectId
  score        Int
  createdAt    DateTime @default(now())

  indicator  Indicator  @relation(fields: [indicatorId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])
}

model IndicatorEvidence {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  indicatorId String   @db.ObjectId
  evaluateeId String   @db.ObjectId
  filename    String
  createdAt   DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id])
  evaluatee User      @relation(fields: [evaluateeId], references: [id])
}